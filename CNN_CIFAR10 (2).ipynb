   "id": "8bef3f3f-5103-4474-8638-85fbcf72d3e3",
   "metadata": {},
   "outputs": [],
   "source": [
    "import torch \n",
    "import torch.nn as nn\n",
    "import torch.optim as optim\n",
    "import torchvision  # Library for computer vision tasks.Includes datasets and image transformations.\n",
    "from torchvision.datasets import CIFAR10"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 2,
   "id": "67f78cff-c319-4a90-9e12-299995b6e584",
   "metadata": {},
   "outputs": [],
   "source": [
    "# Datasets and DataLoaders\n",
    "from torch.utils.data import DataLoader\n",
    "import torchvision.transforms as transforms # Used to modify images (resize, normalize, convert to tensor, etc.)\n",
    "\n",
    "# image => scale (0,1) => normalize => (-1,1)\n",
    "transform = transforms.Compose([  # Compose() → Applies multiple transformations in order.\n",
    "    transforms.ToTensor(), #Converts image (0–255 pixels) → Tensor (0–1 scale).\n",
    "    transforms.Normalize((0.5,0.5,0.5) , (0.5,0.5,0.5)) #Makes values range from (0,1) → (-1,1) , mean & std = 0.5\n",
    "])\n",
    "\n",
    "trainset = CIFAR10(root = \"../data\" , train=True , download=True , transform=transform)\n",
    "testset = CIFAR10(root = \"../data\" , train=False , download=True , transform=transform)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 3,
   "id": "211ecce7-696b-40d5-b82b-479925b3e2da",
   "metadata": {},
   "outputs": [],
   "source": [
    "trainloader = DataLoader(trainset , batch_size = 64 , shuffle=True)\n",
    "testloader = DataLoader(testset , batch_size = 64)"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "6e70a657-113b-4ff4-a9a0-04924e502a34",
   "metadata": {},
   "source": [
    "# Build the CNN"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "id": "f549fca5-249b-4c46-9399-8531f5429bdf",
   "metadata": {
    "jp-MarkdownHeadingCollapsed": true
   },
   "outputs": [],
   "source": [
    "class CNN(nn.Module):\n",
    "    def __init__(self):\n",
    "        super(CNN , self).__init__()\n",
    "\n",
    "        self.conv_layers = nn.Sequential( #Sequential → Runs layers one after another automatically.\n",
    "            # Input channels = 3 (RGB image)\n",
    "            # Output channels = 32 (creates 32 feature maps)\n",
    "            # Kernel size = 3×3\n",
    "            #Padding=1 → Keeps image size same\n",
    "            nn.Conv2d(3 , 32 , kernel_size=3 , padding=1),\n",
    "            nn.ReLU(),\n",
    "            nn.MaxPool2d(2 , 2), # kernel size = 2 , stride = 2ddddd\n",
    "\n",
    "            0.\n",
    "\n",
    "            nn.Conv2d(32 , 64 , kernel_size=3 , padding=1),\n",
    "            nn.ReLU(),\n",
    "            nn.MaxPool2d(2 , 2), #Reduces size by half.32×32 → 16×16 \n",
    "\n",
    "            nn.Conv2d(64 , 128 , kernel_size=3 , padding=1),\n",
    "            nn.ReLU(),\n",
    "            nn.MaxPool2d(2 , 2) \n",
    "        )\n",
    "        # final output after convo_layers = 128 feature maps , each of size 4 × 4\n",
    "        self.fc_layers = nn.Sequential(\n",
    "            nn.Linear(4*4*128 , 256),\n",
    "            nn.ReLU(),\n",
    "\n",
    "            nn.Linear(256 ,10)\n",
    "        )\n",
    "\n",
    "    def forward(self , x):\n",
    "        x = self.conv_layers(x) #Pass input through conv layers.\n",
    "        x = x.view(x.size(0) , -1) # faltteing\n",
    "        x = self.fc_layers(x)\n",
    "\n",
    "        return x #Returns prediction scores (logits)."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 5,
   "id": "86f1b128-cacb-4fc6-b46f-d71931ce8524",
   "metadata": {},
   "outputs": [],
   "source": [
    "model = CNN()\n",
    "device = torch.device(\"cuda\" if torch.cuda.is_available() else \"cpu\")\n",
    "model = model.to(device)"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 6,
   "id": "6c721a1a-f61b-43f4-b2ff-1f01f8f24db6",
   "metadata": {},
   "outputs": [],
   "source": [
    "criterion = nn.CrossEntropyLoss() #Automatically applies: Softmax\n",
    "optimizer = optim.Adam(model.parameters())"
   ]
  },
  {
   "cell_type": "markdown",
   "id": "c2996b69-792a-442c-8554-d0e8a4769383",
   "metadata": {},
   "source": [
    "# Training the CNN"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 8,
   "id": "64b4c823-b682-4668-bef9-c2e099efc01a",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "Epoch1/10 ==> train_loss= 0.9414683619271154 ==> val_loss= 0.8832728701412298 \n",
      "Epoch2/10 ==> train_loss= 0.755871128967351 ==> val_loss= 0.8033477088827996 \n",
      "Epoch3/10 ==> train_loss= 0.6238645190168219 ==> val_loss= 0.7496038445621539 \n",
      "Epoch4/10 ==> train_loss= 0.5125854021448004 ==> val_loss= 0.7117486609395143 \n",
      "Epoch5/10 ==> train_loss= 0.42719687942577445 ==> val_loss= 0.77721344703322 \n",
      "Epoch6/10 ==> train_loss= 0.3410516217293794 ==> val_loss= 0.7830895244315931 \n",
      "Epoch7/10 ==> train_loss= 0.2664955483982935 ==> val_loss= 0.8472596987797196 \n",
      "Epoch8/10 ==> train_loss= 0.20735072182096026 ==> val_loss= 0.9644998086106246 \n",
      "Epoch9/10 ==> train_loss= 0.16098442020090034 ==> val_loss= 1.0566698164696906 \n",
      "Epoch10/10 ==> train_loss= 0.12828750773797484 ==> val_loss= 1.2141068828333714 \n"
     ]
    }
   ],
   "source": [
    "epochs = 10\n",
    "train_losses = []\n",
    "validate_losses = []\n",
    "for epoch in range(epochs):\n",
    "    epoch_training_loss = 0.0\n",
    "\n",
    "    for images, labels in trainloader:\n",
    "       
    "        images = images.to(device)\n",
    "        labels = labels.to(device)\n",
    "\n",
    "        optimizer.zero_grad()\n",
    "\n",
    "        output = model(images)\n",
    "\n",
    "        loss = criterion(output, labels)\n",
    "        loss.backward()\n",
    "        optimizer.step()\n",
    "\n",
    "        epoch_training_loss += loss.item()\n",
    "        train_losses.append(epoch_training_loss)\n",
    "\n",
    "\n",
    "    # Validation \n",
    "    model.eval()\n",
    "    val_loss = 0.0\n",
    "    val_correct = 0\n",
    "    val_total = 0\n",
    "\n",
    "    with torch.no_grad():\n",
    "        for images , labels in testloader:\n",
    "            images = images.to(device)\n",
    "            labels = labels.to(device)\n",
    "\n",
    "            outputs = model(images)\n",
    "            loss = criterion(outputs, labels)\n",
    "\n",
    "            val_loss += loss.item()\n",
    "            _,predicted = torch.max(outputs , 1)\n",
    "\n",
    "            val_correct += (predicted==labels).sum().item()\n",
    "            val_total += labels.size(0)\n",
    "            \n",
    "        val_accuracy = 100 * (val_correct/val_total)\n",
    "        epoch_val_loss = val_loss / len(testloader)\n",
    "        validate_losses.append(epoch_val_loss)\n",
    "\n",
    "        print(f\"Epoch{epoch+1}/{epochs} ==> train_loss= {epoch_training_loss/len(trainloader)} ==> val_loss= {val_loss/len(testloader)} \")"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": 14,
   "id": "44eecc43-3a34-430f-a75c-0fe304103131",
   "metadata": {},
   "outputs": [
    {
     "name": "stdout",
     "output_type": "stream",
     "text": [
      "accuracy = 74.75\n"
     ]
    }
   ],
   "source": [
    "correct_labels = 0\n",
    "total_labels = 0\n",
    "\n",
    "model.eval()\n",
    "\n",
    "with torch.no_grad():\n",
    "    for images , labels in testloader:\n",
    "        images = images.to(device)\n",
    "        labels = labels.to(device)\n",
    "        outputs = model(images)\n",
    "        _,predicted = torch.max(outputs , 1)\n",
    "\n",
    "        correct_labels += (predicted == labels).sum().item()\n",
    "        total_labels += labels.size(0)\n",
    "print(f\"accuracy = {(correct_labels/total_labels)*100}\")"
   ]
  },
